# Neon PostgreSQL - 接続プーラURL（ランタイム用）
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Neon PostgreSQL - 直接接続URL（prisma db push / migrate 用）
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"

# JWT署名シークレット（32文字以上のランダム文字列）
# 生成例: openssl rand -base64 32
JWT_SECRET="your-secret-key-min-32-chars-here"

# NODE_ENV（Vercelでは自動設定）
NODE_ENV="development"
