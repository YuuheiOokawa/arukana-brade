# Neon PostgreSQL - 接続プーラURL（ランタイム用 / Vercel Functions・Prisma クエリ）
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# Neon PostgreSQL - 直接接続URL（prisma migrate deploy / db push 用）
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# JWT署名シークレット（32文字以上のランダム文字列）
# 生成例: openssl rand -base64 32
JWT_SECRET="your-secret-key-min-32-chars-here"

# NODE_ENV（Vercelでは自動設定されるので不要）
# NODE_ENV="development"
