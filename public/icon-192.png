<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <rect width="512" height="512" rx="96" fill="#08081a"/>
  <rect x="32" y="32" width="448" height="448" rx="72" fill="#12122a" stroke="#8b5cf6" stroke-width="4"/>
  <!-- Sword -->
  <line x1="256" y1="80" x2="256" y2="380" stroke="#c4b5fd" stroke-width="18" stroke-linecap="round"/>
  <!-- Cross guard -->
  <line x1="160" y1="200" x2="352" y2="200" stroke="#f0c040" stroke-width="14" stroke-linecap="round"/>
  <!-- Pommel -->
  <circle cx="256" cy="400" r="28" fill="#f0c040"/>
  <!-- Glow -->
  <circle cx="256" cy="256" r="100" fill="none" stroke="#8b5cf6" stroke-width="2" opacity="0.4"/>
  <!-- Text -->
  <text x="256" y="475" font-family="serif" font-size="36" font-weight="bold" fill="#c4b5fd" text-anchor="middle">ARCANA</text>
</svg>
